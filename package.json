{
  "name": "@nochoco-lee/arbiter",
  "version": "0.1.2",
  "description": "Agentic Resource Broker & Interceptor for coordinating shared test bridges and hardware.",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "arbiter": "./dist/shim/index.js"
  },
  "files": [
    "dist/**/*",
    "!dist/tests/**"
  ],
  "scripts": {
    "test": "npx ts-node src/tests/run_json_suite.ts",
    "test:unit": "node --require ts-node/register --test src/tests/unit/*.test.ts",
    "test:remote": "echo \"Remote tests disabled\"",
    "test:robustness": "npx ts-node src/tests/stress/run_all.ts",
    "test:all": "npm run test && npm run test:unit && npm run test:robustness",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "test-engineering",
    "resource-broker",
    "agentic-coding",
    "device-farm",
    "emulator",
    "adb",
    "llm-agent"
  ],
  "author": "nochoco-lee <nochoco.lee@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nochoco-lee/arbiter.git"
  },
  "homepage": "https://github.com/nochoco-lee/arbiter#readme",
  "bugs": {
    "url": "https://github.com/nochoco-lee/arbiter/issues"
  },
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/serialport": "^8.0.5",
    "@types/ws": "^8.18.1",
    "mocha": "^11.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "arg": "^5.0.2",
    "blessed": "^0.1.81",
    "js-yaml": "^4.1.1",
    "serialport": "^13.0.0",
    "ws": "^8.20.0"
  }
}
